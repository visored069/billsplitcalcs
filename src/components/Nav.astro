---
interface Props {
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;

const links = [
  { href: '/', label: 'Home' },
  { href: '/app', label: 'Split Bills' },
  { href: '/global-split', label: 'Global Split' },
  { href: '/features', label: 'Features' },
];
---

<header class="sticky top-0 z-50 bg-(--color-canvas)/95 backdrop-blur-sm border-b border-(--color-hairline)">
  <nav class="max-w-[1400px] mx-auto px-4 sm:px-6 h-16 grid grid-cols-[auto_1fr_auto] md:grid-cols-[1fr_auto_1fr] items-center gap-2">
    <!-- Logo -->
    <a href="/" class="justify-self-start flex items-center gap-2 font-semibold text-sm text-(--color-ink) tracking-tight flex-shrink-0">
      <img src="/favicon.svg" width="24" height="24" alt="" class="w-6 h-6 rounded-md flex-shrink-0" />
      <span class="whitespace-nowrap">BillSplit<span class="text-(--color-mute) font-normal">Calcs</span></span>
    </a>

    <!-- Center links (desktop) — dead-centered via symmetric 1fr side columns -->
    <div class="hidden md:flex items-center gap-2">
      {links.map((link) => (
        <a href={link.href} class={`text-sm font-medium px-3 py-2 rounded-full bg-(--color-primary) text-(--color-on-primary) hover:opacity-90 transition-opacity duration-150 ${currentPath === link.href ? 'ring-2 ring-inset ring-red-500' : ''}`}>
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right CTAs -->
    <div class="justify-self-end flex items-center gap-1 flex-shrink-0">
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="inline-flex items-center justify-center w-7 h-7 text-(--color-body) hover:text-(--color-ink) hover:bg-(--color-canvas-soft-2) rounded-md transition-colors duration-150"
      >
        <svg id="theme-icon-sun" width="16" height="16" viewBox="0 0 16 16" fill="none" class="hidden">
          <circle cx="8" cy="8" r="3.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 1v1.5M8 13.5V15M15 8h-1.5M2.5 8H1M12.7 3.3l-1 1M4.3 11.7l-1 1M12.7 12.7l-1-1M4.3 4.3l-1-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <svg id="theme-icon-moon" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M13.5 9.8A5.8 5.8 0 016.2 2.5a5.8 5.8 0 106.8 8.8.6.6 0 01.5.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Nav pills (mobile/tablet) — same pill style as desktop, always visible, horizontally scrollable -->
  <div class="md:hidden border-t border-(--color-hairline)">
    <div class="nav-scroll flex items-center gap-2 px-4 py-2.5 overflow-x-auto max-w-[1400px] mx-auto">
      {links.map((link) => (
        <a href={link.href} class={`flex-shrink-0 text-sm font-medium px-3.5 py-2 rounded-full whitespace-nowrap bg-(--color-primary) text-(--color-on-primary) hover:opacity-90 transition-opacity duration-150 ${currentPath === link.href ? 'ring-2 ring-inset ring-red-500' : ''}`}>
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<style>
  .nav-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .nav-scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function updateThemeIcon() {
    const isDark = document.documentElement.classList.contains('dark');
    document.getElementById('theme-icon-sun')?.classList.toggle('hidden', !isDark);
    document.getElementById('theme-icon-moon')?.classList.toggle('hidden', isDark);
  }

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateThemeIcon();
  });

  updateThemeIcon();
</script>
