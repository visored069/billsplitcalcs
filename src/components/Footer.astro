---
---

<footer class="bg-(--color-canvas) border-t border-(--color-hairline)">
  <div class="max-w-[1400px] mx-auto px-6 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-6 h-6 rounded-md bg-(--color-primary) flex items-center justify-center flex-shrink-0">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 11L7 3L12 11H2Z" fill="white"/>
            </svg>
          </div>
          <span class="font-semibold text-sm text-(--color-ink)">BillSplit<span class="text-(--color-mute) font-normal">Calcs</span></span>
        </div>
        <p class="text-sm text-(--color-body) leading-relaxed max-w-[200px]">
          The cleanest way to split expenses with anyone, anywhere.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="font-mono text-xs uppercase tracking-widest text-(--color-mute) mb-4">Product</h4>
        <ul class="space-y-3">
          <li><a href="/app" class="text-sm text-(--color-body) hover:text-(--color-ink) transition-colors">Split Bills</a></li>
          <li><a href="/#features" class="text-sm text-(--color-body) hover:text-(--color-ink) transition-colors">Features</a></li>
          <li><a href="/#how-it-works" class="text-sm text-(--color-body) hover:text-(--color-ink) transition-colors">How it works</a></li>
        </ul>
      </div>

      <!-- Use Cases -->
      <div>
        <h4 class="font-mono text-xs uppercase tracking-widest text-(--color-mute) mb-4">Use Cases</h4>
        <ul class="space-y-3">
          <li><span class="text-sm text-(--color-body)">Group Trips</span></li>
          <li><span class="text-sm text-(--color-body)">Restaurants</span></li>
          <li><span class="text-sm text-(--color-body)">Shared Housing</span></li>
          <li><span class="text-sm text-(--color-body)">Events & Parties</span></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-mono text-xs uppercase tracking-widest text-(--color-mute) mb-4">Legal</h4>
        <ul class="space-y-3">
          <li><a href="/privacy" class="text-sm text-(--color-body) hover:text-(--color-ink) transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-(--color-body) hover:text-(--color-ink) transition-colors">Terms of Use</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-(--color-hairline) pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-(--color-mute)">© 2026 BillSplitCalcs. All rights reserved.</p>
      <p class="text-xs text-(--color-mute)">No signup required. No data stored on servers.</p>
    </div>
  </div>
</footer>
