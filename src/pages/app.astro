  { code: 'LKR', symbol: '₨', name: 'Sri Lankan Rupee' },
  { code: 'NPR', symbol: '₨', name: 'Nepalese Rupee' },
  { code: 'MMK', symbol: 'K', name: 'Myanmar Kyat' },
  { code: 'KHR', symbol: '៛', name: 'Cambodian Riel' },
  { code: 'TWD', symbol: 'NT$', name: 'Taiwan Dollar' },
];

// ─── Category icons ───────────────────────────────────────────────────────────
const CATEGORY_ICONS = {
  general: '📦', food: '🍽️', transport: '🚗',
  accommodation: '🏠', entertainment: '🎭', shopping: '🛍️', other: '📌',
};

// ─── Member emoji avatars ─────────────────────────────────────────────────────
const AVATARS = ['😀','🙂','😎','🤓','🤩','😄','🧑','👩','👨','🦊','🐼','🐙','🦁','🐸','🐧'];

// ─── Utility: generate ID ─────────────────────────────────────────────────────
const uid = () => Math.random().toString(36).slice(2, 9);

// ─── State ────────────────────────────────────────────────────────────────────
let state = {
  id: uid(),
  name: '',
  currency: CURRENCIES[0],
  language: 'en',
  members: [],
  expenses: [],
};

function t(key) {
  const lang = state.language;
  return (TRANSLATIONS[lang] || TRANSLATIONS.en)[key] || key;
}

// ─── Persistence ─────────────────────────────────────────────────────────────
function saveState() {
  try {
    localStorage.setItem('bsc_state', JSON.stringify(state));
    const encoded = btoa(JSON.stringify(state));
    history.replaceState(null, '', `/app#${encoded}`);
  } catch (_) {}
}

function loadState() {
  try {
    const hash = location.hash.slice(1);
    if (hash) {
      const parsed = JSON.parse(atob(hash));
      if (parsed && parsed.id) { state = parsed; return; }
    }
  } catch (_) {}
  try {
    const saved = localStorage.getItem('bsc_state');
    if (saved) { state = JSON.parse(saved); return; }
  } catch (_) {}
}

// ─── Settlement algorithm ────────────────────────────────────────────────────
function computeBalances() {
  const balances = {};
  state.members.forEach(m => { balances[m.id] = 0; });

  state.expenses.forEach(exp => {
    const { amount, paidBy, splitType, splitWith } = exp;
    if (!splitWith || splitWith.length === 0) return;

    // compute each person's share
    const shares = computeShares(amount, splitType, splitWith);
    shares.forEach(({ memberId, share }) => {
      if (balances[memberId] !== undefined) balances[memberId] -= share;
    });
    if (balances[paidBy] !== undefined) balances[paidBy] += amount;
  });

  return balances;
}

function computeShares(amount, splitType, splitWith) {
  if (splitType === 'equal') {
    const share = amount / splitWith.length;
    return splitWith.map(({ memberId }) => ({ memberId, share }));
  } else if (splitType === 'percentage') {
    return splitWith.map(({ memberId, value }) => ({
      memberId, share: amount * (value / 100),
    }));
  } else { // shares
    const totalShares = splitWith.reduce((s, { value }) => s + (value || 1), 0);
    return splitWith.map(({ memberId, value }) => ({
      memberId, share: amount * ((value || 1) / totalShares),
    }));
  }
}

function computeSettlements(balances) {
  const eps = 0.005;
  const creditors = [];
  const debtors = [];

  Object.entries(balances).forEach(([id, bal]) => {
    if (bal > eps) creditors.push({ id, amount: bal });
    else if (bal < -eps) debtors.push({ id, amount: -bal });
  });

  creditors.sort((a, b) => b.amount - a.amount);
  debtors.sort((a, b) => b.amount - a.amount);

  const settlements = [];
  let ci = 0, di = 0;

  while (ci < creditors.length && di < debtors.length) {
    const cred = creditors[ci];
    const debt = debtors[di];
    const transfer = Math.min(cred.amount, debt.amount);

    settlements.push({
      from: debt.id,
      to: cred.id,
      amount: transfer,
    });

    cred.amount -= transfer;
    debt.amount -= transfer;

    if (cred.amount < eps) ci++;
    if (debt.amount < eps) di++;
  }

  return settlements;
}

// ─── Format currency ─────────────────────────────────────────────────────────
function fmt(amount) {
  const sym = state.currency.symbol;
  const code = state.currency.code;
  try {
    return new Intl.NumberFormat('en-US', {
      style: 'currency', currency: code, minimumFractionDigits: 2, maximumFractionDigits: 2,
    }).format(amount);
  } catch (_) {
    return `${sym}${amount.toFixed(2)}`;
  }
}

// ─── DOM helpers ─────────────────────────────────────────────────────────────
function getMember(id) { return state.members.find(m => m.id === id); }
function getMemberName(id) { return getMember(id)?.name || id; }

// ─── Render: members ─────────────────────────────────────────────────────────
function renderMembers() {
  const list = document.getElementById('member-list');
  const count = document.getElementById('member-count');
  count.textContent = String(state.members.length);

  list.innerHTML = state.members.map(m => `
    <div class="flex items-center gap-3 px-4 py-2.5 group hover:bg-(--color-canvas-soft) transition-colors">
      <span class="text-lg leading-none">${m.emoji}</span>
      <span class="flex-1 text-sm text-(--color-ink)">${escHtml(m.name)}</span>
      <button
        onclick="removeMember('${m.id}')"
        class="opacity-0 group-hover:opacity-100 w-5 h-5 flex items-center justify-center text-(--color-mute) hover:text-(--color-error) transition-all rounded"
        title="Remove"
      >
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 2l6 6M8 2L2 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
  `).join('');

  renderSplitWith();
  renderPaidBySelect();
}

// ─── Render: paid-by select ──────────────────────────────────────────────────
function renderPaidBySelect() {
  const sel = document.getElementById('exp-paid-by');
  const curVal = sel.value;
  sel.innerHTML = `<option value="">Select person...</option>` +
    state.members.map(m => `<option value="${m.id}" ${m.id === curVal ? 'selected' : ''}>${escHtml(m.name)}</option>`).join('');
}

// ─── Render: split-with ──────────────────────────────────────────────────────
function renderSplitWith() {
  const container = document.getElementById('split-with-list');
  const empty = document.getElementById('split-with-empty');
  const splitType = document.querySelector('input[name="split-type"]:checked')?.value || 'equal';

  if (state.members.length === 0) {
    container.innerHTML = '';
    empty.style.display = '';
    syncToggleAllCheckbox();
    return;
  }
  empty.style.display = 'none';

  container.innerHTML = state.members.map(m => {
    const extraInput = splitType !== 'equal' ? `
      <input
        type="number" min="0" step="${splitType === 'percentage' ? '1' : '0.5'}"
        placeholder="${splitType === 'percentage' ? '0%' : '1'}"
        class="split-val-input w-16 h-7 px-2 text-xs text-(--color-ink) bg-(--color-canvas-soft) border border-(--color-hairline) rounded text-right focus:outline-none focus:ring-1 focus:ring-(--color-primary)"
        data-member="${m.id}"
      />
    ` : '';
    return `
      <label class="split-with-item flex items-center gap-2.5 cursor-pointer group">
        <input type="checkbox" value="${m.id}" class="split-member-check w-3.5 h-3.5 rounded border-(--color-hairline) accent-(--color-primary)" checked />
        <span class="text-base">${m.emoji}</span>
        <span class="flex-1 text-sm text-(--color-ink)">${escHtml(m.name)}</span>
        ${extraInput}
      </label>
    `;
  }).join('');

  syncToggleAllCheckbox();
}

// ─── Keep the "All" checkbox in sync with individual member checkboxes ──────
function syncToggleAllCheckbox() {
  const toggleAll = document.getElementById('toggle-all-members');
  const checks = document.querySelectorAll('.split-member-check');
  if (checks.length === 0) {
    toggleAll.checked = false;
    toggleAll.indeterminate = false;
    return;
  }
  const checkedCount = [...checks].filter(c => c.checked).length;
  toggleAll.checked = checkedCount === checks.length;
  toggleAll.indeterminate = checkedCount > 0 && checkedCount < checks.length;
}

// ─── Render: expense list ────────────────────────────────────────────────────
function renderExpenses() {
  const list = document.getElementById('expense-list');
  const empty = document.getElementById('expense-empty');
  const countEl = document.getElementById('expense-count');
  const totalEl = document.getElementById('expense-total-display');

  const total = state.expenses.reduce((s, e) => s + e.amount, 0);
  countEl.textContent = `${state.expenses.length} item${state.expenses.length !== 1 ? 's' : ''}`;
  totalEl.textContent = state.expenses.length ? fmt(total) : '';

  if (state.expenses.length === 0) {
    list.innerHTML = '';
    empty.style.display = '';
    return;
  }
  empty.style.display = 'none';

  list.innerHTML = state.expenses.map(exp => {
    const payer = getMemberName(exp.paidBy);
    const icon = CATEGORY_ICONS[exp.category] || '📦';
    const splitLabel = exp.splitWith?.length
      ? exp.splitWith.map(s => getMemberName(s.memberId)).join(', ')
      : '—';
    return `
      <div class="flex items-start gap-3 px-4 py-3 group hover:bg-(--color-canvas-soft) transition-colors">
        <span class="text-lg mt-0.5">${icon}</span>
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-2">
            <span class="text-sm font-medium text-(--color-ink) truncate">${escHtml(exp.description || 'Expense')}</span>
            <span class="text-sm font-mono font-medium text-(--color-ink) flex-shrink-0">${fmt(exp.amount)}</span>
          </div>
          <div class="text-xs text-(--color-mute) mt-0.5">
            Paid by <span class="text-(--color-body)">${escHtml(payer)}</span>
            · Split: <span class="text-(--color-body) capitalize">${exp.splitType}</span>
            · <span class="text-(--color-body) truncate">${escHtml(splitLabel)}</span>
          </div>
        </div>
        <button
          onclick="removeExpense('${exp.id}')"
          class="opacity-0 group-hover:opacity-100 w-5 h-5 flex items-center justify-center text-(--color-mute) hover:text-(--color-error) transition-all rounded flex-shrink-0 mt-0.5"
          title="Remove"
        >
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 2l6 6M8 2L2 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
    `;
  }).join('');
}

// ─── Render: results ─────────────────────────────────────────────────────────
function renderResults() {
  const balances = computeBalances();
  const settlements = computeSettlements({ ...balances });

  // Settlement list
  const settlList = document.getElementById('settlement-list');
  const settlEmpty = document.getElementById('settlement-empty');
  if (settlements.length === 0) {
    settlList.innerHTML = '';
    settlEmpty.style.display = '';
  } else {
    settlEmpty.style.display = 'none';
    settlList.innerHTML = settlements.map(s => {
      const fromMember = getMember(s.from);
      const toMember = getMember(s.to);
      return `
        <div class="flex items-center gap-4 px-4 py-3.5">
          <div class="flex items-center gap-2 flex-1 min-w-0">
            <span class="text-lg">${fromMember?.emoji || '🧑'}</span>
            <div class="min-w-0">
              <span class="text-sm font-medium text-(--color-ink)">${escHtml(fromMember?.name || s.from)}</span>
              <span class="text-xs text-(--color-mute) mx-1.5">${t('owes')}</span>
              <span class="text-sm font-medium text-(--color-ink)">${escHtml(toMember?.name || s.to)}</span>
            </div>
          </div>
          <span class="text-lg">${toMember?.emoji || '🧑'}</span>
          <span class="font-mono text-sm font-semibold text-(--color-ink) ml-2 flex-shrink-0">${fmt(s.amount)}</span>
        </div>
      `;
    }).join('');
  }

  // Balance list
  const balList = document.getElementById('balance-list');
  const balEmpty = document.getElementById('balance-empty');
  if (state.members.length === 0) {
    balList.innerHTML = '';
    balEmpty.style.display = '';
    return;
  }
  balEmpty.style.display = 'none';

  const totalPaid = state.expenses.reduce((s, e) => s + e.amount, 0);
  balList.innerHTML = state.members.map(m => {
    const bal = balances[m.id] || 0;
    const paid = state.expenses.filter(e => e.paidBy === m.id).reduce((s, e) => s + e.amount, 0);
    const isPositive = bal > 0.005;
    const isNegative = bal < -0.005;

    return `
      <div class="flex items-center gap-3 px-4 py-3">
        <span class="text-lg">${m.emoji}</span>
        <div class="flex-1">
          <div class="text-sm font-medium text-(--color-ink)">${escHtml(m.name)}</div>
          <div class="text-xs text-(--color-mute)">Paid ${fmt(paid)}</div>
        </div>
        <div class="text-right">
          <div class="text-sm font-mono font-medium ${isPositive ? 'text-green-600' : isNegative ? 'text-(--color-error)' : 'text-(--color-mute)'}">
            ${isPositive ? '+' : ''}${fmt(bal)}
          </div>
          <div class="text-xs text-(--color-mute)">${isPositive ? 'gets back' : isNegative ? 'owes' : 'even'}</div>
        </div>
      </div>
    `;
  }).join('');
}

// ─── Render: all ─────────────────────────────────────────────────────────────
function render() {
  renderMembers();
  renderExpenses();
  renderResults();
  updateI18n();
  updateCurrencySymbols();
}

function updateI18n() {
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    el.textContent = t(key);
  });
}

function updateCurrencySymbols() {
  const sym = state.currency.symbol;
  document.querySelectorAll('#exp-currency-symbol, #tip-currency-symbol').forEach(el => {
    el.textContent = sym;
  });
}

// ─── Members CRUD ─────────────────────────────────────────────────────────────
function addMember(name) {
  name = name.trim();
  if (!name) return;
  const emoji = AVATARS[state.members.length % AVATARS.length];
  state.members.push({ id: uid(), name, emoji });
  saveState(); render();
}

window.removeMember = function(id) {
  state.members = state.members.filter(m => m.id !== id);
  state.expenses = state.expenses.map(exp => ({
    ...exp,
    splitWith: exp.splitWith?.filter(s => s.memberId !== id) || [],
  }));
  saveState(); render();
};

// ─── Expenses CRUD ────────────────────────────────────────────────────────────
function addExpense() {
  const desc = document.getElementById('exp-desc').value.trim();
  const amountRaw = parseFloat(document.getElementById('exp-amount').value);
  const paidBy = document.getElementById('exp-paid-by').value;
  const category = document.getElementById('exp-category').value;
  const splitType = document.querySelector('input[name="split-type"]:checked')?.value || 'equal';

  if (!paidBy) { alert('Please select who paid.'); return false; }
  if (!amountRaw || amountRaw <= 0) { alert('Please enter a valid amount.'); return false; }

  const checkedMembers = [...document.querySelectorAll('.split-member-check:checked')]
    .map(cb => cb.value);
  if (checkedMembers.length === 0) { alert('Select at least one person to split with.'); return false; }

  const splitWith = checkedMembers.map(memberId => {
    const valInput = document.querySelector(`.split-val-input[data-member="${memberId}"]`);
    const value = valInput ? parseFloat(valInput.value) || (splitType === 'percentage' ? 0 : 1) : 1;
    return { memberId, value };
  });

  if (splitType === 'percentage') {
    const total = splitWith.reduce((s, sw) => s + sw.value, 0);
    if (Math.abs(total - 100) > 0.5) {
      alert(`Percentages must add up to 100%. Currently: ${total.toFixed(1)}%`);
      return false;
    }
  }

  state.expenses.push({
    id: uid(), description: desc || 'Expense', amount: amountRaw,
    paidBy, category, splitType, splitWith,
    date: new Date().toISOString(),
  });

  // Reset form
  document.getElementById('exp-desc').value = '';
  document.getElementById('exp-amount').value = '';

  saveState(); render();
  return true;
}

window.removeExpense = function(id) {
  state.expenses = state.expenses.filter(e => e.id !== id);
  saveState(); render();
};

// ─── Tip calculator ──────────────────────────────────────────────────────────
function updateTipCalc() {
  const subtotal = parseFloat(document.getElementById('tip-subtotal').value) || 0;
  const pct = parseFloat(document.getElementById('tip-pct').value) || 0;
  const tip = subtotal * pct / 100;
  const total = subtotal + tip;
  document.getElementById('tip-amount').textContent = subtotal ? fmt(tip) : '—';
  document.getElementById('tip-total').textContent = subtotal ? fmt(total) : '—';
}

// ─── Share ────────────────────────────────────────────────────────────────────
function shareMessage() {
  const groupName = state.name || 'Bill Split';
  return `${groupName} — split the bill with me:`;
}

function copyShareLink() {
  const url = location.href;
  const finish = () => {
    const btn = document.getElementById('share-btn');
    const span = btn.querySelector('span');
    const orig = span.textContent;
    span.textContent = t('copied');
    setTimeout(() => { span.textContent = orig; }, 2000);
  };
  if (navigator.clipboard) {
    navigator.clipboard.writeText(url).then(finish).catch(() => prompt('Copy this link:', url));
  } else {
    prompt('Copy this link:', url);
  }
}

function shareVia(platform) {
  const url = location.href;
  const text = shareMessage();

  if (platform === 'copy') { copyShareLink(); return; }

  if (platform === 'email') {
    location.href = `mailto:?subject=${encodeURIComponent(text)}&body=${encodeURIComponent(text + '\n' + url)}`;
    return;
  }

  const shareUrls = {
    whatsapp: `https://wa.me/?text=${encodeURIComponent(text + ' ' + url)}`,
    facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`,
    telegram: `https://t.me/share/url?url=${encodeURIComponent(url)}&text=${encodeURIComponent(text)}`,
  };
  const target = shareUrls[platform];
  if (target) window.open(target, '_blank', 'noopener,noreferrer,width=600,height=600');
}

// ─── Copy results ─────────────────────────────────────────────────────────────
function copyResults() {
  const balances = computeBalances();
  const settlements = computeSettlements({ ...balances });
  const groupName = state.name || 'Bill Split';
  let text = `${groupName} — Settlement\n\n`;
  if (settlements.length === 0) {
    text += t('settled');
  } else {
    settlements.forEach(s => {
      text += `${getMemberName(s.from)} → ${getMemberName(s.to)}: ${fmt(s.amount)}\n`;
    });
  }
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-results-btn');
      const orig = btn.textContent;
      btn.textContent = t('copied');
      setTimeout(() => { btn.textContent = orig; }, 2000);
    });
  } else {
    prompt('Copy this:', text);
  }
}

// ─── Escape HTML ──────────────────────────────────────────────────────────────
function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ─── Init ─────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  loadState();

  // Populate currency select
  const currSel = document.getElementById('currency-select');
  CURRENCIES.forEach(c => {
    const opt = document.createElement('option');
    opt.value = c.code;
    opt.textContent = `${c.symbol} ${c.code} — ${c.name}`;
    if (c.code === state.currency.code) opt.selected = true;
    currSel.appendChild(opt);
  });

  // Set language select
  const langSel = document.getElementById('lang-select');
  langSel.value = state.language;

  // Set group name
  document.getElementById('group-name').value = state.name;

  render();

  // ── Event listeners ──

  document.getElementById('group-name').addEventListener('input', e => {
    state.name = e.target.value;
    saveState();
  });

  currSel.addEventListener('change', e => {
    state.currency = CURRENCIES.find(c => c.code === e.target.value) || CURRENCIES[0];
    saveState(); render(); updateTipCalc();
  });

  langSel.addEventListener('change', e => {
    state.language = e.target.value;
    saveState(); render();
  });

  // Jump to results section
  document.getElementById('jump-to-results').addEventListener('click', () => {
    document.getElementById('panel-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // Add member
  document.getElementById('add-member-btn').addEventListener('click', () => {
    const input = document.getElementById('new-member-input');
    addMember(input.value);
    input.value = '';
    input.focus();
  });
  document.getElementById('new-member-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      const input = e.target;
      addMember(input.value);
      input.value = '';
    }
  });

  // Split type change
  document.querySelectorAll('input[name="split-type"]').forEach(radio => {
    radio.addEventListener('change', () => renderSplitWith());
  });

  // Toggle all members
  document.getElementById('toggle-all-members').addEventListener('change', e => {
    document.querySelectorAll('.split-member-check').forEach(c => { c.checked = e.target.checked; });
  });

  // Keep the "All" checkbox in sync when an individual member is (un)checked
  document.getElementById('split-with-list').addEventListener('change', e => {
    if (e.target.classList.contains('split-member-check')) syncToggleAllCheckbox();
  });

  // Add expense
  document.getElementById('add-expense-btn').addEventListener('click', addExpense);

  // Press Enter in the expense form to add it, then jump straight to the results
  function addExpenseAndShowResults(e) {
    if (e.key !== 'Enter') return;
    e.preventDefault();
    if (addExpense()) {
      document.getElementById('panel-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }
  document.getElementById('exp-desc').addEventListener('keydown', addExpenseAndShowResults);
  document.getElementById('exp-amount').addEventListener('keydown', addExpenseAndShowResults);

  // Tip calculator
  document.getElementById('tip-subtotal').addEventListener('input', updateTipCalc);
  document.getElementById('tip-pct').addEventListener('input', updateTipCalc);
  document.querySelectorAll('.tip-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('tip-pct').value = btn.dataset.pct;
      updateTipCalc();
    });
  });

  // Add tip as expense
  document.getElementById('add-tip-expense').addEventListener('click', () => {
    const subtotal = parseFloat(document.getElementById('tip-subtotal').value) || 0;
    const pct = parseFloat(document.getElementById('tip-pct').value) || 0;
    const total = subtotal + subtotal * pct / 100;
    if (total <= 0) return;
    document.getElementById('exp-desc').value = `Dinner (incl. ${pct}% tip)`;
    document.getElementById('exp-amount').value = total.toFixed(2);
    document.getElementById('exp-desc').focus();
  });

  // Share menu
  const shareBtn = document.getElementById('share-btn');
  const shareMenu = document.getElementById('share-menu');
  shareBtn.addEventListener('click', e => {
    e.stopPropagation();
    shareMenu.classList.toggle('hidden');
  });
  shareMenu.querySelectorAll('.share-option').forEach(opt => {
    opt.addEventListener('click', () => {
      shareVia(opt.dataset.platform);
      shareMenu.classList.add('hidden');
    });
  });
  document.addEventListener('click', e => {
    if (!shareMenu.classList.contains('hidden') && !shareMenu.contains(e.target) && e.target !== shareBtn) {
      shareMenu.classList.add('hidden');
    }
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') shareMenu.classList.add('hidden');
  });

  document.getElementById('copy-results-btn').addEventListener('click', copyResults);

  // Clear expenses (and therefore the results) without touching members/group name
  document.getElementById('clear-expenses-btn').addEventListener('click', () => {
    if (state.expenses.length === 0) return;
    if (!confirm(t('clearExpensesConfirm'))) return;
    state.expenses = [];
    saveState(); render();
  });

  // Reset
  document.getElementById('reset-btn').addEventListener('click', () => {
    if (!confirm(t('resetConfirm'))) return;
    localStorage.removeItem('bsc_state');
    history.replaceState(null, '', '/app');
    state = { id: uid(), name: '', currency: CURRENCIES[0], language: 'en', members: [], expenses: [] };
    document.getElementById('group-name').value = '';
    currSel.value = 'USD';
    langSel.value = 'en';
    render();
  });
});
</script>
